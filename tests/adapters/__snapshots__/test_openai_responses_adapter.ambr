        dict({
          'content': '''
            Calculate customer lifetime value segments and predict churn risk. Group
            customers into segments based on spending patterns and calculate days since last
            purchase to identify churn risk.
          ''',
          'control_plane_step': None,
          'function_call': None,
          'logprobs': None,
