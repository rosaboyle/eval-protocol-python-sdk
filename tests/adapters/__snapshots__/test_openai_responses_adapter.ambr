          'role': 'assistant',
          'tool_call_id': None,
          'tool_calls': list([
            dict({
              'function': dict({
                'arguments': '{"query":"WITH customer_metrics AS (\\n  SELECT \\n    c.customer_id,\\n    (c.first_name || \' \' || c.last_name) AS customer_name,\\n    c.country,\\n    COALESCE(SUM(i.total), 0) AS lifetime_value,\\n    COUNT(i.invoice_id) AS orders,\\n    COALESCE(AVG(i.total), 0) AS avg_order_value,\\n    MAX(i.invoice_date) AS last_purchase_date\\n  FROM customer c\\n  LEFT JOIN invoice i ON i.customer_id = c.customer_id\\n  GROUP BY c.customer_id, customer_name, c.country\\n),\\nscored AS (\\n  SELECT \\n    *,\\n    CASE \\n      WHEN last_purchase_date IS NULL THEN NULL\\n      ELSE (current_date - last_purchase_date::date)\\n    END AS days_since_last_purchase_raw,\\n    PERCENT_RANK() OVER (ORDER BY lifetime_value) AS lv_percent_rank\\n  FROM customer_metrics\\n),\\nsegmented AS (\\n  SELECT \\n    customer_id,\\n    customer_name,\\n    country,\\n    lifetime_value,\\n    orders,\\n    avg_order_value,\\n    last_purchase_date,\\n    CASE \\n      WHEN days_since_last_purchase_raw IS NULL THEN NULL\\n      ELSE GREATEST(0, days_since_last_purchase_raw)\\n    END AS days_since_last_purchase,\\n    CASE \\n      WHEN lifetime_value = 0 THEN \'No Spend\'\\n      WHEN lv_percent_rank >= 0.8 THEN \'High\'\\n      WHEN lv_percent_rank >= 0.5 THEN \'Medium\'\\n      ELSE \'Low\'\\n    END AS lv_segment,\\n    CASE \\n      WHEN last_purchase_date IS NULL THEN \'Churn Risk: No purchases\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) > 365 THEN \'High Risk\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) BETWEEN 181 AND 365 THEN \'Medium Risk\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) BETWEEN 91 AND 180 THEN \'Low Risk\'\\n      ELSE \'Active\'\\n    END AS churn_risk\\n  FROM scored\\n)\\nSELECT \\n  customer_id,\\n  customer_name,\\n  country,\\n  lifetime_value,\\n  orders,\\n  avg_order_value,\\n  last_purchase_date,\\n  days_since_last_purchase,\\n  lv_segment,\\n  churn_risk\\nFROM segmented\\nWHERE churn_risk = \'High Risk\'\\nORDER BY days_since_last_purchase DESC, lifetime_value DESC\\nLIMIT 10;"}',
                'name': 'execute_sql',
              }),
              'id': 'call_QklYCtJeAzMn8iMshl0PaYXg',
              'type': 'function',
            }),
            dict({
              'function': dict({
                'arguments': '{"query":"WITH customer_metrics AS (\\n  SELECT \\n    c.customer_id,\\n    (c.first_name || \' \' || c.last_name) AS customer_name,\\n    c.country,\\n    COALESCE(SUM(i.total), 0) AS lifetime_value,\\n    COUNT(i.invoice_id) AS orders,\\n    COALESCE(AVG(i.total), 0) AS avg_order_value,\\n    MAX(i.invoice_date) AS last_purchase_date\\n  FROM customer c\\n  LEFT JOIN invoice i ON i.customer_id = c.customer_id\\n  GROUP BY c.customer_id, customer_name, c.country\\n),\\nscored AS (\\n  SELECT \\n    *,\\n    CASE \\n      WHEN last_purchase_date IS NULL THEN NULL\\n      ELSE (current_date - last_purchase_date::date)\\n    END AS days_since_last_purchase_raw,\\n    PERCENT_RANK() OVER (ORDER BY lifetime_value) AS lv_percent_rank\\n  FROM customer_metrics\\n),\\nsegmented AS (\\n  SELECT \\n    customer_id,\\n    customer_name,\\n    country,\\n    lifetime_value,\\n    orders,\\n    avg_order_value,\\n    last_purchase_date,\\n    CASE \\n      WHEN days_since_last_purchase_raw IS NULL THEN NULL\\n      ELSE GREATEST(0, days_since_last_purchase_raw)\\n    END AS days_since_last_purchase,\\n    CASE \\n      WHEN lifetime_value = 0 THEN \'No Spend\'\\n      WHEN lv_percent_rank >= 0.8 THEN \'High\'\\n      WHEN lv_percent_rank >= 0.5 THEN \'Medium\'\\n      ELSE \'Low\'\\n    END AS lv_segment,\\n    CASE \\n      WHEN last_purchase_date IS NULL THEN \'Churn Risk: No purchases\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) > 365 THEN \'High Risk\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) BETWEEN 181 AND 365 THEN \'Medium Risk\'\\n      WHEN (CASE WHEN days_since_last_purchase_raw IS NULL THEN NULL ELSE GREATEST(0, days_since_last_purchase_raw) END) BETWEEN 91 AND 180 THEN \'Low Risk\'\\n      ELSE \'Active\'\\n    END AS churn_risk\\n  FROM scored\\n)\\nSELECT \\n  lv_segment,\\n  COUNT(*) AS customers,\\n  ROUND(AVG(lifetime_value)::numeric, 2) AS avg_ltv,\\n  ROUND(AVG(COALESCE(days_since_last_purchase, 0))::numeric, 1) AS avg_days_since_last_purchase,\\n  SUM(CASE WHEN churn_risk = \'High Risk\' THEN 1 ELSE 0 END) AS high_risk_customers\\nFROM segmented\\nGROUP BY lv_segment\\nORDER BY \\n  CASE lv_segment WHEN \'High\' THEN 1 WHEN \'Medium\' THEN 2 WHEN \'Low\' THEN 3 WHEN \'No Spend\' THEN 4 ELSE 5 END;"}',
