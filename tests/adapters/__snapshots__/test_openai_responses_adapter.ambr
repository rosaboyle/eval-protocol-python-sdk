          'tool_call_id': None,
          'tool_calls': list([
            dict({
              'function': dict({
                'arguments': '{"query":"WITH RECURSIVE emp_tree AS (\\n  SELECT \\n    e.employee_id,\\n    (e.first_name || \' \' || e.last_name) AS name,\\n    e.reports_to,\\n    1 AS level,\\n    (e.first_name || \' \' || e.last_name) AS path\\n  FROM employee e\\n  WHERE e.reports_to IS NULL\\n  UNION ALL\\n  SELECT \\n    c.employee_id,\\n    (c.first_name || \' \' || c.last_name) AS name,\\n    c.reports_to,\\n    et.level + 1 AS level,\\n    (et.path || \' > \' || c.first_name || \' \' || c.last_name) AS path\\n  FROM employee c\\n  JOIN emp_tree et ON c.reports_to = et.employee_id\\n)\\nSELECT name, level, path\\nFROM emp_tree\\nORDER BY path;"}',
                'name': 'execute_sql',
              }),
